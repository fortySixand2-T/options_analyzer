{
  "chain_provider": "yfinance",
  "cache_ttl_chain": 900,
  "cache_ttl_history": 3600,
  "filter": {
    "min_dte": 20,
    "max_dte": 60,
    "min_delta": 0.15,
    "max_delta": 0.50,
    "min_open_interest": 100,
    "max_spread_pct": 15.0,
    "moneyness_range": [0.85, 1.15]
  },
  "garch": {
    "history_days": 120,
    "min_returns": 30
  },
  "scoring_weights": {
    "edge": 0.40,
    "iv_rank": 0.25,
    "liquidity": 0.20,
    "greeks": 0.15
  }
}
